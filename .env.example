# ============================================================
# SIHADIR — Environment Configuration
# Universitas Dian Nuswantoro
# ============================================================
# Copy file ini ke .env dan sesuaikan nilai-nilainya
# cp .env.example .env

# ------- Application -------
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000

# ------- Database -------
DB_DATABASE=sihadir_db
DB_USERNAME=sihadir_user
DB_PASSWORD=sihadir_pass
DB_ROOT_PASSWORD=sihadir_root

# ------- AI Engine -------
FLASK_ENV=development
CONFIDENCE_THRESHOLD=0.80
AI_ENGINE_TIMEOUT=30
LOG_LEVEL=INFO

# ------- Laravel App Key (generate dengan: php artisan key:generate) -------
APP_KEY=
